# Auto-ChemInstruct Environment Configuration
# Copy this file to .env and fill in your values

# LLM Provider
LLM_PROVIDER=openrouter  # openrouter, openai, openai-compatible
LLM_MODEL=openai/gpt-4o
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your-api-key-here
LLM_TEMPERATURE=0.8
LLM_MAX_TOKENS=4096

# Alternative: OpenAI direct
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Chemistry Simulation
XTB_BINARY=xtb
XTB_METHOD=GFN2-xTB
ENABLE_XTB=true
XTB_TIMEOUT=300
XTB_MAX_ATOMS=100

# Pipeline
BATCH_SIZE=50
MAX_ITERATIONS=10000
CHECKPOINT_DIR=.checkpoints
MAX_CONCURRENT_LLM=5
MAX_CONCURRENT_XTB=4

# Database
CHROMA_PERSIST_DIR=.chromadb
SQLITE_PATH=.state/autochem.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/autochem.log

# Experiment Tracking (optional)
WANDB_PROJECT=auto-cheminstruct
ENABLE_WANDB=false

# Dataset Output
DATASET_DIR=datasets
DATASET_NAME=auto-cheminstruct-v1
